<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#F8F9FA">

    <!-- CABEÇALHO DO PERFIL FIXO NO TOPO -->
    <LinearLayout
        android:id="@+id/header_perfil"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:padding="24dp"
        android:gravity="center_vertical"
        android:elevation="4dp">

        <!-- Truque: CardView arredondado para fazer uma foto de perfil circular! -->
        <androidx.cardview.widget.CardView
            android:layout_width="70dp"
            android:layout_height="70dp"
            app:cardCornerRadius="35dp"
            app:cardElevation="0dp"
            android:layout_marginEnd="16dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:drawable/ic_menu_myplaces"
                android:backgroundTint="#BDBDBD" />
        </androidx.cardview.widget.CardView>

        <!-- Informações do Usuário -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Elisson Victor"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#212121"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3 avaliações publicadas"
                android:textSize="14sp"
                android:textColor="#FF9800"
                android:textStyle="bold"
                android:layout_marginTop="2dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Membro desde 2026"
                android:textSize="12sp"
                android:textColor="#757575"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ÁREA ROLÁVEL (Lista de Publicações) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header_perfil"
        android:layout_above="@+id/menu_inferior"
        android:clipToPadding="false"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- TÍTULO DA LISTA -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Minhas Publicações"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#2196F3"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"
                android:paddingStart="4dp"/>

            <!-- Card 1: Ama Brownie -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_ama_brownie"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Ama Brownie" android:textStyle="bold" android:textSize="18sp" android:textColor="#212121"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⭐ 5.0" android:textStyle="bold" android:textColor="#FF9800"/>
                    </LinearLayout>

                    <!-- Linha divisória fina -->
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginTop="8dp" android:layout_marginBottom="8dp"/>

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text='"Atendimento impecável e os melhores doces da cidade. Recomendo muito!"' android:textSize="14sp" android:textStyle="italic" android:textColor="#6C757D" android:lineSpacingExtra="2dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 2: Lanchonete da UNIFOR -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_lanchonete"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Lanchonete da UNIFOR" android:textStyle="bold" android:textSize="18sp" android:textColor="#212121"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⭐ 3.5" android:textStyle="bold" android:textColor="#FF9800"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginTop="8dp" android:layout_marginBottom="8dp"/>

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text='"Ótimo para quebrar um galho entre as aulas, mas achei o salgado um pouco caro."' android:textSize="14sp" android:textStyle="italic" android:textColor="#6C757D" android:lineSpacingExtra="2dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 3: Fondue em Guaramiranga -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_fondue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Fondue em Guaramiranga" android:textStyle="bold" android:textSize="18sp" android:textColor="#212121"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⭐ 4.8" android:textStyle="bold" android:textColor="#FF9800"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginTop="8dp" android:layout_marginBottom="8dp"/>

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text='"Clima perfeito, comida maravilhosa. Só a fila de espera que estava um pouco longa."' android:textSize="14sp" android:textStyle="italic" android:textColor="#6C757D" android:lineSpacingExtra="2dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- O Menu Inferior Pregado na Base -->
    <LinearLayout
        android:id="@+id/menu_inferior"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="12dp">

        <Button android:id="@+id/btn_menu_inicio" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="Início" android:background="#00000000" android:textColor="#495057" />
        <Button android:id="@+id/btn_menu_add" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="+" android:textSize="28sp" android:background="#00000000" android:textColor="#6750A4" />
        <Button android:id="@+id/btn_menu_analises" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="Meu Perfil" android:textStyle="bold" android:background="#00000000" android:textColor="#2196F3" />
    </LinearLayout>
</RelativeLayout>